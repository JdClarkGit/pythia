# Wallet
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Polymarket API (obtain from https://polymarket.com/profile)
POLY_API_KEY=your_api_key
POLY_API_SECRET=your_api_secret
POLY_API_PASSPHRASE=your_passphrase

# Chain
POLYGON_RPC_URL=https://polygon-rpc.com

# Optional: Override config.toml values
# MAX_TRADE_SIZE_USDC=100.0
# MIN_PROFIT_PCT=0.10
# TOTAL_CAPITAL_USDC=300.0

# Alerts
WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
